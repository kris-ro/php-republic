{
    "name": "kris-ro/php-republic",
    "description": "Super slim MVC framework written in PHP with layered JSON config, PHP templating, data validation, account authentication and others",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-pdo_mysql": "*",
        "ext-curl": "*",
        "kris-ro/php-config": "^1.0",
        "kris-ro/validator": "^1.0",
        "kris-ro/php-dependency-injection": "^1.0",
        "kris-ro/php-database-model": "^1.0",
        "monolog/monolog": "^3.10",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "suggest": {
        "ext-intl": "Advanced dates and currencies format.",
        "ext-mbstring": "Needed for UTF8 strings.",
        "ext-bcmath": "Recommanded for financial operations.",
        "ext-gd": "Image processing.",
        "ext-openssl": "Security functions",
        "ext-json": "JSON pasing", 
        "ext-filter": "Data validation", 
        "ext-xml": "XML processing", 
        "ext-simplexml": "XML processing", 
        "ext-dom": "XML processing"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "KrisRo\\PhpRepublic\\": "src/",
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "cristianradu",
            "email": "kris_ro@yahoo.com"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "post-create-project-cmd": [
            "@php ./republic instal"
        ]
    }
}
